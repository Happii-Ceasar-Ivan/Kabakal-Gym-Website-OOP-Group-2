{
  "ConnectionStrings": {
    "NeonPostgres": "Host=<YOUR_NEON_HOST>.neon.tech;Port=5432;Database=kabakal_gym;Username=<YOUR_USERNAME>;Password=<YOUR_PASSWORD>;SSL Mode=Require;Trust Server Certificate=true"
  },
