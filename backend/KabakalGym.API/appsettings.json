    "http://127.0.0.1:5500",
    "http://localhost:5173",
    "https://kabakal-gym.azurewebsites.net",
    "https://kabakalgym.vercel.app",
    "https://kabakal-gym.vercel.app"
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
